# ─────────────────────────────────────────────────────────────────────
# areyouagentic.com — environment variables
# Copy to .env and fill in values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────

# Node environment: development | test | production
NODE_ENV=development

# ── App URLs ─────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Postgres (matches docker-compose.yml) ────────────────────────────
DATABASE_URL=postgresql://areyouagentic:areyouagentic@localhost:5432/areyouagentic?schema=public

# ── Redis (matches docker-compose.yml; used by BullMQ) ───────────────
REDIS_URL=redis://localhost:6379

# ── Anthropic (Claude) ───────────────────────────────────────────────
# WORKER ONLY. The API and web services must NOT have access to this key
# — secrets-isolation between the public-facing API and the worker is
# part of our threat model. Provision it only to the worker deployment.
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudflare R2 (S3-compatible object storage) ─────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=areyouagentic-artifacts
R2_PUBLIC_URL=https://artifacts.areyouagentic.com

# ── App secrets ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-long-random-string
JWT_SECRET=replace-me-with-a-long-random-string

# ── Observability ────────────────────────────────────────────────────
# Sentry. Leave blank to disable. NEXT_PUBLIC_SENTRY_DSN is the same value
# but exposed to the browser bundle, so use a DSN you're comfortable
# publishing client-side.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Worker liveness/readiness HTTP server.
HEALTH_PORT=4001

# Worker tuning (optional — see apps/worker/src/lib/env.ts for defaults).
WORKER_CONCURRENCY=3
JOB_TIMEOUT_MS=90000

# Log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# /api/metrics is gated by basic auth. Leave both blank to disable the route.
METRICS_USERNAME=
METRICS_PASSWORD=

# ── Bot protection (Cloudflare Turnstile) ────────────────────────────
# Optional. Leave blank to disable the captcha entirely (default).
# To enable, set BOTH:
#   - TURNSTILE_SECRET_KEY (API): server-side siteverify; when set, the API
#     enforces a valid token on POST /api/analyze and fails closed.
#   - NEXT_PUBLIC_TURNSTILE_SITE_KEY (web): renders the widget and widens the
#     CSP to allow Cloudflare's script/iframe. Must be set if the secret is,
#     or the form can't produce a token and submissions will be rejected.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Build metadata (set by CI for image tags / Sentry releases) ──────
GIT_SHA=
IMAGE_TAG=
