{
  "name": "@areyouagentic/worker",
  "version": "0.0.0",
  "private": true,
  "description": "BullMQ workers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "retention": "node dist/retention.js",
    "retention:dev": "tsx src/retention.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@areyouagentic/db": "workspace:*",
    "@areyouagentic/shared": "workspace:*",
    "@sentry/node": "^8.40.0",
    "bullmq": "^5.21.2",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@areyouagentic/config": "workspace:*",
    "@types/node": "^20.16.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
