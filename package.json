{
  "name": "areyouagentic",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for areyouagentic.com",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "@types/node": "^20.16.11"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "esbuild": ">=0.25.0",
      "postcss": ">=8.5.10"
    }
  }
}
