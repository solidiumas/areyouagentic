{
  "name": "@areyouagentic/analyzers",
  "version": "0.0.0",
  "private": true,
  "description": "Core analysis modules (reused by worker)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@areyouagentic/shared": "workspace:*",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@areyouagentic/config": "workspace:*",
    "@types/node": "^20.16.11",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
