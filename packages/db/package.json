{
  "name": "@areyouagentic/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema, migrations, and singleton client",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:seed": "dotenv -e ../../.env -- prisma db seed",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules/.prisma"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@areyouagentic/shared": "workspace:*",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@areyouagentic/config": "workspace:*",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
