// areyouagentic.com — Prisma schema
//
// JSON columns (`findings`, `recommendations`, `evidence`) are typed via
// Zod schemas in `@areyouagentic/shared`. Always parse on read and validate
// on write to keep the JSONB structure honest.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model AnalysisJob {
  id            String    @id @default(cuid())
  url           String
  // Normalized form used for deduplication (lowercased host, sorted query, etc.)
  normalizedUrl String
  status        JobStatus @default(PENDING)
  errorMessage  String?

  // SHA-256 (hex) of the one-time delete token handed to the submitter at
  // creation. Lets the creator delete their report without an account; the
  // plaintext token is never stored. Null for legacy rows + deduped requests.
  deleteTokenHash String?

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  report Report?

  @@index([normalizedUrl, createdAt])
  @@index([status])
}

model Report {
  // cuid2: cryptographically-random, unguessable id. The report id is the
  // only access control on a public-but-unlisted report, so it must not be
  // predictable the way a v1 cuid (timestamp + counter) is. Existing v1 ids
  // keep working; new reports get a cuid2.
  id    String      @id @default(cuid(2))
  jobId String      @unique
  job   AnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  overallScore Int    // 0-100
  grade        String // A | B | C | D | F

  // Per-dimension scores (0-100)
  machineReadabilityScore Int
  structuredDataScore     Int
  agentSignalsScore       Int
  actionabilityScore      Int
  performanceScore        Int
  contentClarityScore     Int

  // Structured payloads — see @areyouagentic/shared for the Zod schemas.
  findings        Json // Findings  (array of Finding)
  recommendations Json // Recommendations
  evidence        Json // Evidence (array of EvidenceItem)

  pageTitle String?
  finalUrl  String

  // LLM-generated narrative laid over the deterministic findings.
  // verdict: one-sentence summary; quickWins: ≤3 highest-leverage fixes.
  // Null when no Anthropic key is configured at analysis time.
  llmVerdict   String?
  llmQuickWins Json? // string[]

  createdAt DateTime @default(now())

  @@index([overallScore])
  @@index([createdAt])
}
