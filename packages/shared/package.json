{
  "name": "@areyouagentic/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types, Zod schemas, and constants",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@areyouagentic/config": "workspace:*",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
